{
  "name": "cypforge",
  "language": "en",
  "purpose": "Strict orchestration shell for CYPForge CYP450 HEME/CYM ligand Amber workflows.",
  "not_a_new_simulation_package": true,
  "production_md_allowed": false,
  "status_semantics": ["PASS", "WARN", "FAIL"],
  "ordered_modules": [
    {
      "skill": "cypforge.environment_check",
      "file": "environment_check.md",
      "required_before": ["cypforge.core1_prepare_heme_cym"]
    },
    {
      "skill": "cypforge.core1_prepare_heme_cym",
      "file": "core1_prepare_heme_cym.md",
      "required_before": ["cypforge.core2_prepare_ligand_resp_gaff2"]
    },
    {
      "skill": "cypforge.core2_prepare_ligand_resp_gaff2",
      "file": "core2_prepare_ligand_resp_gaff2.md",
      "required_before": ["cypforge.core3_finalize_protonation"]
    },
    {
      "skill": "cypforge.core3_finalize_protonation",
      "file": "core3_finalize_protonation.md",
      "required_before": ["cypforge.core3_solvate_ionize"]
    },
    {
      "skill": "cypforge.core3_solvate_ionize",
      "file": "core3_solvate_ionize.md",
      "required_before": ["cypforge.core3_render_pre_md"]
    },
    {
      "skill": "cypforge.core3_render_pre_md",
      "file": "core3_render_pre_md.md",
      "required_before": ["cypforge.core3_run_pre_md"]
    },
    {
      "skill": "cypforge.core3_run_pre_md",
      "file": "core3_run_pre_md.md",
      "required_before": ["cypforge.global_audit"]
    },
    {
      "skill": "cypforge.global_audit",
      "file": "global_audit.md",
      "required_before": ["cypforge.equilibration_decision"]
    },
    {
      "skill": "cypforge.equilibration_decision",
      "file": "equilibration_decision.md",
      "required_before": ["cypforge.production_readiness_check"]
    },
    {
      "skill": "cypforge.production_readiness_check",
      "file": "production_readiness_check.md",
      "required_before": []
    }
  ],
  "absolute_stop_conditions": [
    "Amber/tLeap/pmemd.cuda/cpptraj unavailable",
    "Python cannot import cypforge_core",
    "ligand atom mapping missing or failed",
    "SDF/PDB ligand element mismatch",
    "RESP charge injection not verified",
    "unresolved parmchk2 ATTN NEEDS REVISION",
    "HEM Fe missing",
    "CYM remains CYS or CYM SG has HG",
    "Fe-S or Fe-N topology cannot be confirmed",
    "transmembrane trimming requested without exact human-provided chain:residue ranges and explicit confirmation",
    "GLH/HID/CYM residue rename fails",
    "dry charge does not match expected model",
    "tleap has critical missing parameter or unknown atom/residue",
    "solvated system is not neutral after ionization",
    "restrained MD command lacks -ref",
    "restrained MD uses iwrap=1",
    "free MD uses -ref",
    "pmemd.cuda reports SHAKE/vlimit/Ewald/NaN/PME fatal pattern",
    "global audit status is FAIL"
  ],
  "allowed_equilibration_decisions": [
    "STOP_FIX_ENVIRONMENT",
    "STOP_FIX_CORE1",
    "STOP_FIX_CORE2",
    "STOP_FIX_PROTONATION",
    "STOP_FIX_SOLVATION",
    "STOP_FIX_PRE_MD",
    "WARN_HUMAN_REVIEW",
    "ALLOW_1_5_NS_FREE_EQUILIBRATION",
    "ALLOW_PRODUCTION_SETUP_ONLY_AFTER_EXTENDED_EQUILIBRATION"
  ]
}
